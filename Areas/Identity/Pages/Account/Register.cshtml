@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="card shadow border-0 mt-4">
    <div class="card-header bg-secondary bg-gradient py-4">
        <div class="row">
            <div class="col-12 text-center">
                <h2 class="text-white">@ViewData["Title"]</h2>
            </div>
        </div>
    </div>

    <div class="card-body p-4">
        <form id="registerForm" class="row" asp-route-returnUrl="@Model.ReturnUrl" method="post">

            <h3 class="border-bottom pb-3 mb-4 text-secondary text-center">
                Create a new account
            </h3>

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <!-- Email -->
            <div class="form-floating mb-3 col-12">
                <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="name@example.com" />
                <label asp-for="Input.Email" class="ms-2"></label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <!-- Name -->
            <div class="form-floating mb-3 col-12">
                <input asp-for="Input.Name" class="form-control" placeholder="Name" />
                <label asp-for="Input.Name" class="ms-2"></label>
                <span asp-validation-for="Input.Name" class="text-danger"></span>
            </div>

            <!-- Phone -->
            <div class="form-floating mb-3 col-md-6">
                <input asp-for="Input.PhoneNumber" class="form-control" placeholder="Phone Number" />
                <label asp-for="Input.PhoneNumber" class="ms-2"></label>
                <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
            </div>

            <!-- Role -->
            <div class="form-floating mb-3 col-md-6">
                <select asp-for="Input.Role" asp-items="@Model.Input.RoleList" class="form-select">
                    <option disabled selected>-- Select Role --</option>
                </select>
                <label asp-for="Input.Role" class="ms-2"></label>
                <span asp-validation-for="Input.Role" class="text-danger"></span>
            </div>

            <!-- Street Address -->
            <div class="form-floating mb-3 col-12">
                <input asp-for="Input.StreetAddress" class="form-control" placeholder="Street Address" />
                <label asp-for="Input.StreetAddress" class="ms-2"></label>
                <span asp-validation-for="Input.StreetAddress" class="text-danger"></span>
            </div>

            <!-- City -->
            <div class="form-floating mb-3 col-md-4">
                <input asp-for="Input.City" class="form-control" placeholder="City" />
                <label asp-for="Input.City" class="ms-2"></label>
                <span asp-validation-for="Input.City" class="text-danger"></span>
            </div>

            <!-- State -->
            <div class="form-floating mb-3 col-md-4">
                <input asp-for="Input.State" class="form-control" placeholder="State" />
                <label asp-for="Input.State" class="ms-2"></label>
                <span asp-validation-for="Input.State" class="text-danger"></span>
            </div>

            <!-- Postal Code -->
            <div class="form-floating mb-3 col-md-4">
                <input asp-for="Input.PostalCode" class="form-control" placeholder="Postal Code" />
                <label asp-for="Input.PostalCode" class="ms-2"></label>
                <span asp-validation-for="Input.PostalCode" class="text-danger"></span>
            </div>

            <!-- Password -->
            <div class="form-floating mb-3 col-md-6">
                <input asp-for="Input.Password" class="form-control" autocomplete="new-password" placeholder="Password" />
                <label asp-for="Input.Password" class="ms-2"></label>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <!-- Confirm Password -->
            <div class="form-floating mb-4 col-md-6">
                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" placeholder="Confirm Password" />
                <label asp-for="Input.ConfirmPassword" class="ms-2"></label>
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <div class="col-12">
                <button id="registerSubmit" type="submit" class="w-100 btn btn-primary btn-lg">
                    Register
                </button>
            </div>

        </form>

        <div class="mt-5">
            <h3>Use another service to register.</h3>
            <hr />

            @if ((Model.ExternalLogins?.Count ?? 0) == 0)
            {
                <div>
                    <p>
                        There are no external authentication services configured.
                        See this
                        <a href="https://go.microsoft.com/fwlink/?LinkID=532715">
                            article about setting up this ASP.NET application to support logging in via external services.
                        </a>
                    </p>
                </div>
            }
            else
            {
                <form id="external-account"
                      asp-page="./ExternalLogin"
                      asp-route-returnUrl="@Model.ReturnUrl"
                      method="post">

                    @foreach (var provider in Model.ExternalLogins!)
                    {
                        <button type="submit"
                                class="btn btn-outline-primary me-2"
                                name="provider"
                                value="@provider.Name"
                                title="Log in using your @provider.DisplayName account">
                            @provider.DisplayName
                        </button>
                    }
                </form>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}