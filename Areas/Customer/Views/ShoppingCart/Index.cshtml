@model ShoppingCartVM

<div class="card shadow border-0 mt-4 mb-4">
    <div class="card-header bg-secondary bg-gradient ml-0 py-3">
        <div class="row">
            <div class="col-12 text-center">
                <h2 class="text-white py-2">Shopping Cart</h2>
            </div>
        </div>
    </div>
    <div class="card-body">
        <div class="row pb-3">
            <a asp-area="Customer" asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary form-control">
                Continue Shopping
            </a>
        </div>

        @foreach (var cart in Model.ShoppingCartList)
        {
            <div class="row pb-3">
                <div class="col-2 col-md-1">
                    <img src="@cart.Product.ImageUrl" class="rounded w-100" />
                </div>
                <div class="col-6 col-md-8">
                    <h5>@cart.Product.Title</h5>
                    <p>@cart.Product.Description</p>
                </div>
                <div class="col-2 text-center">
                    <h6>Price</h6>
                    <p>@cart.Price.ToString("c") x @cart.Count</p>
                </div>
                <div class="col-2 col-md-1 text-center">
                    <div class="w-100 btn-group" role="group">
                        <a asp-action="Plus" asp-route-cartId="@cart.Id" class="btn btn-outline-secondary">
                            <i class="bi bi-plus-square"></i>
                        </a>
                        <a asp-action="Minus" asp-route-cartId="@cart.Id" class="btn btn-outline-secondary">
                            <i class="bi bi-dash-square"></i>
                        </a>
                    </div>
                </div>
                <div class="col-1 text-center">
                    <a asp-action="Remove" asp-route-cartId="@cart.Id" class="btn btn-danger">
                        <i class="bi bi-trash-fill"></i>
                    </a>
                </div>
            </div>
            <hr />
        }

        <div class="row">
            <div class="col-6"></div>
            <div class="col-6">
                <div class="row">
                    <div class="col-6 text-end">
                        <h3>Total (USD)</h3>
                    </div>
                    <div class="col-6 text-end">
                        <h3>@Model.OrderHeader.OrderTotal.ToString("c")</h3>
                    </div>
                </div>
                <div class="row">
                    <div class="col-6"></div>
                    <div class="col-6">
                        <a asp-action="Summary" class="btn btn-primary bg-gradient border-0 form-control">
                            Summary
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
